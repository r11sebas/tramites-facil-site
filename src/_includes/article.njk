---
layout: base.njk
---
{% from "icons.njk" import categoryIcon %}
{% from "article-card.njk" import card %}
<article class="article">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | dump | safe }},
    "description": {{ description | dump | safe }},
    "datePublished": "{{ date | htmlDateString }}",
    "author": {
      "@type": "Organization",
      "name": "{{ site.name }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.name }}"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Artículos",
        "item": "{{ site.url }}/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ category | dump | safe }},
        "item": "{{ site.url }}/categoria/{{ category | categorySlug }}/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ title | dump | safe }},
        "item": "{{ site.url }}{{ page.url }}"
      }
    ]
  }
  </script>

  <nav class="breadcrumbs">
    <a href="/">Artículos</a> <span class="sep">›</span>
    <a class="badge" href="/categoria/{{ category | categorySlug }}/" style="--cat-color: {{ category | categoryColor }}">{{ category }}</a>
  </nav>

  <span class="icon-bubble icon-bubble-lg" style="--cat-color: {{ category | categoryColor }}">{{ categoryIcon(category) }}</span>
  <h1 style="--cat-color: {{ category | categoryColor }}">{{ title }}</h1>
  <p class="article-date">
    Actualizado: {{ date | readableDate }} · Por el
    <a href="/sobre-nosotros/">equipo editorial de {{ site.name }}</a>
  </p>

  <a class="share-whatsapp" href="https://wa.me/?text={{ (title + ' — ' + site.url + page.url) | urlencode }}" target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.6-.8-1.9-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.5.1-.3-.1-1.2-.4-2.2-1.4-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.3-.4.1-.2 0-.4 0-.5 0-.1-.6-1.4-.8-1.9-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2 3 4.8 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.6-.7 1.9-1.3.2-.6.2-1.1.2-1.3-.1-.1-.3-.2-.6-.3z"/><path d="M12 2C6.5 2 2 6.5 2 12c0 1.9.5 3.6 1.4 5.1L2 22l5-1.3c1.4.8 3.1 1.3 4.9 1.3 5.5 0 10-4.5 10-10S17.5 2 12 2zm0 18c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3C4.4 15 4 13.5 4 12c0-4.4 3.6-8 8-8s8 3.6 8 8-3.6 8-8 8z"/></svg>
    Compartir por WhatsApp
  </a>

  <div class="toc-placeholder"></div>

  <div class="article-body">
    {{ content | safe }}
  </div>

  <div class="helpful-widget" data-slug="{{ page.fileSlug }}">
    <p class="helpful-question">¿Te sirvió esta guía?</p>
    <div class="helpful-buttons">
      <button type="button" class="helpful-btn" data-vote="yes">👍 Sí</button>
      <button type="button" class="helpful-btn" data-vote="no">👎 No</button>
    </div>
    <p class="helpful-thanks" hidden>¡Gracias por tu opinión!</p>
  </div>

  <p class="disclaimer">
    Este contenido es informativo y no constituye asesoría legal ni migratoria.
    Verifica siempre los requisitos y montos vigentes en las fuentes oficiales citadas
    (USCIS, IRCC, Cancillería de Colombia o Migración Colombia) antes de tomar decisiones.
  </p>

  {% set related = collections.articulos | relatedArticles(category, page.url, 3) %}
  {% if related.length %}
  <section class="related-articles">
    <h2>También te puede interesar</h2>
    <ul class="article-list">
      {% for post in related %}
        {{ card(post) }}
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</article>
