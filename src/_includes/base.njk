<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title %} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title or site.name }}">
  <meta name="twitter:description" content="{{ description or site.description }}">

  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <a class="logo" href="/">{{ site.name }}</a>
    <nav>
      <a href="/">Artículos</a>
      <a href="/sobre-nosotros/">Sobre nosotros</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>&copy; {{ currentYear }} {{ site.name }}. Contenido informativo, no constituye asesoría legal o migratoria.</p>
    <nav>
      <a href="/privacidad/">Privacidad</a>
      <a href="/terminos/">Términos</a>
    </nav>
  </footer>
</body>
</html>
