<!doctype html>
<html lang="es">
<head>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4724701100955337"
     crossorigin="anonymous"></script>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}{% if title %} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title or site.name }}">
  <meta name="twitter:description" content="{{ description or site.description }}">

  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <a class="logo" href="/"><span class="logo-mark">TF</span>{{ site.name }}</a>
      <nav>
        <a href="/">Artículos</a>
        <a href="/sobre-nosotros/">Sobre nosotros</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>&copy; {{ currentYear }} {{ site.name }}. Contenido informativo, no constituye asesoría legal o migratoria.</p>
      <nav>
        <a href="/privacidad/">Privacidad</a>
        <a href="/terminos/">Términos</a>
      </nav>
    </div>
  </footer>
</body>
</html>
